---
import { Button } from "$lib/components/ui/button";
import { GitCommitHorizontal, Construction } from "@lucide/astro";
import { ModeWatcher } from "mode-watcher";

import "../styles/global.css";
---

<script is:inline>
  const isBrowser = typeof localStorage !== "undefined";
  const getThemePreference = () => {
    if (isBrowser && localStorage.getItem("theme")) {
      return localStorage.getItem("theme");
    }
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  };
  const isDark = getThemePreference() === "dark";
  document.documentElement.classList[isDark ? "add" : "remove"]("dark");

  if (isBrowser) {
    const observer = new MutationObserver(() => {
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"]
    });
  }
</script>

<html lang="en">
  <head>
    <title>Under Construction</title>
  </head>
  <body>
    <ModeWatcher client:load />
    <div class="flex min-h-screen items-center justify-center">
      <div class="flex flex-col items-center gap-6 bg-card p-6">
        <div class="pt-3">
          <Construction size={32} />
        </div>
        <div class="text-xl font-bold tracking-tight">Under Construction!</div>
        <Button size="lg" href="https://github.com/itm154">
          <GitCommitHorizontal />
          Visit my GitHub Profile
        </Button>
      </div>
    </div>
  </body>
</html>
