{
  "compatibility_date": "2026-04-19",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "web",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "preview_urls": true,
  "routes": [
    {
      "pattern": "itm154.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
